# ── WebCEO ────────────────────────────────────────────────────────────────────
# Obtén tu API key en WebCEO → Menú principal → API
WEBCEO_API_KEY=tu_api_key_aqui

# ── Gemini AI (opcional) ──────────────────────────────────────────────────────
# Obtén tu key en console.cloud.google.com → APIs → Generative Language API
GEMINI_API_KEY=tu_gemini_key_aqui

# ── Salida de archivos ────────────────────────────────────────────────────────
OUTPUT_DIR=./output

# ── Datos de la empresa (aparecen en el pie de página del PDF) ────────────────
COMPANY_NAME=Mentalidad Web Ltda
COMPANY_PHONE=+5626643163
COMPANY_URL=www.mentalidadweb.com

# ── Autenticación de la aplicación web ───────────────────────────────────────
# Contraseña para acceder con email @mentalidadweb.com
ADMIN_PASS=cambia-esto-por-una-clave-segura

# Clave secreta para firmar las cookies de sesión (mínimo 32 caracteres)
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria-larga

# ── Google OAuth 2.0 (opcional) ───────────────────────────────────────────────
# Crea las credenciales en console.cloud.google.com → Credenciales → OAuth 2.0
# Authorized redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu_client_secret
